{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "exam.schema.json",
  "type": "object",
  "required": [
    "schemaVersion",
    "id",
    "title",
    "profession",
    "specialization",
    "ordinance",
    "language",
    "papers"
  ],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "type": "string" },
    "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "title": { "type": "string" },
    "profession": { "type": "string" },
    "specialization": { "type": "string" },
    "ordinance": { "type": "string" },
    "examDate": { "type": "string" },
    "language": { "type": "string" },
    "sources": {
      "type": "array",
      "items": { "$ref": "#/$defs/sourceRef" }
    },
    "papers": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/paper" }
    }
  },
  "$defs": {
    "sourceRef": {
      "type": "object",
      "required": ["label", "url"],
      "additionalProperties": false,
      "properties": {
        "label": { "type": "string" },
        "url": { "type": "string" }
      }
    },
    "paper": {
      "type": "object",
      "required": [
        "id",
        "title",
        "durationMinutes",
        "weightPercent",
        "order",
        "instructions",
        "blocks"
      ],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "durationMinutes": { "type": "number" },
        "weightPercent": { "type": "number" },
        "order": { "type": "number" },
        "maxPoints": { "type": "number" },
        "schedule": {
          "type": "object",
          "required": ["startsAt", "endsAt"],
          "additionalProperties": false,
          "properties": {
            "startsAt": { "type": "string" },
            "endsAt": { "type": "string" }
          }
        },
        "instructions": {
          "type": "array",
          "items": { "$ref": "#/$defs/contentBlock" }
        },
        "allowedAids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "blocks": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/questionBlock" }
        }
      }
    },
    "questionBlock": {
      "type": "object",
      "required": [
        "id",
        "title",
        "scope",
        "offeredCount",
        "requiredCount",
        "tasks"
      ],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "scope": {
          "type": "string",
          "enum": ["general", "specialization", "wiso-bound", "wiso-open"]
        },
        "questionRange": { "type": "string" },
        "offeredCount": { "type": "number" },
        "requiredCount": { "type": "number" },
        "defaultDropPolicy": {
          "type": "string",
          "enum": ["last-if-unclear", "manual-review"]
        },
        "tasks": {
          "type": "array",
          "items": { "$ref": "#/$defs/task" }
        }
      }
    },
    "task": {
      "type": "object",
      "required": [
        "id",
        "number",
        "title",
        "topicTags",
        "maxPoints",
        "prompt",
        "subtasks",
        "provenance"
      ],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "number": { "type": "string" },
        "title": { "type": "string" },
        "topicTags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "maxPoints": { "type": "number" },
        "estimatedMinutes": { "type": "number" },
        "prompt": {
          "type": "array",
          "items": { "$ref": "#/$defs/contentBlock" }
        },
        "materials": {
          "type": "array",
          "items": { "$ref": "#/$defs/materialRef" }
        },
        "subtasks": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/subtask" }
        },
        "provenance": { "$ref": "#/$defs/provenance" }
      }
    },
    "subtask": {
      "type": "object",
      "required": ["id", "label", "prompt", "maxPoints", "answerFields"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "operator": {
          "type": "string",
          "enum": [
            "nennen",
            "beschreiben",
            "erlaeutern",
            "begrueden",
            "beurteilen",
            "berechnen",
            "zuordnen",
            "skizzieren",
            "auswaehlen"
          ]
        },
        "prompt": {
          "type": "array",
          "items": { "$ref": "#/$defs/contentBlock" }
        },
        "maxPoints": { "type": "number" },
        "answerFields": {
          "type": "array",
          "items": { "$ref": "#/$defs/answerField" }
        }
      }
    },
    "contentBlock": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": true,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["paragraph", "list", "table", "image", "formula", "pageBreak"]
        },
        "text": { "type": "string" },
        "ordered": { "type": "boolean" },
        "items": {
          "type": "array",
          "items": { "type": "string" }
        },
        "headers": {
          "type": "array",
          "items": { "type": "string" }
        },
        "rows": {
          "type": "array",
          "items": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "assetId": { "type": "string" },
        "caption": { "type": "string" }
      }
    },
    "answerField": {
      "type": "object",
      "required": ["id", "type"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string" },
        "type": {
          "type": "string",
          "enum": [
            "singleChoice",
            "multipleChoice",
            "shortText",
            "longText",
            "shortTextList",
            "table",
            "calculation",
            "fileUpload",
            "drawingUpload"
          ]
        },
        "minLines": { "type": "number" },
        "maxLines": { "type": "number" },
        "items": { "type": "number" },
        "rows": { "type": "number" },
        "columns": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "label"],
            "additionalProperties": false,
            "properties": {
              "id": { "type": "string" },
              "label": { "type": "string" }
            }
          }
        },
        "options": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "label"],
            "additionalProperties": false,
            "properties": {
              "id": { "type": "string" },
              "label": { "type": "string" }
            }
          }
        },
        "minSelect": { "type": "number" },
        "maxSelect": { "type": "number" },
        "showWorkArea": { "type": "boolean" },
        "unit": { "type": "string" },
        "acceptedMimeTypes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "materialRef": {
      "type": "object",
      "required": ["materialId", "usage"],
      "additionalProperties": false,
      "properties": {
        "materialId": { "type": "string" },
        "usage": {
          "type": "string",
          "enum": ["task-figure", "attachment", "source-text", "layout-sample"]
        }
      }
    },
    "provenance": {
      "type": "object",
      "required": ["sourceType", "basis", "notDerivedFromProtectedExam"],
      "additionalProperties": false,
      "properties": {
        "sourceType": {
          "type": "string",
          "enum": ["original-generated", "user-provided"]
        },
        "basis": { "type": "string" },
        "notDerivedFromProtectedExam": { "type": "boolean" },
        "rightsStatus": {
          "type": "string",
          "enum": ["generated", "user-confirmed", "requires-review"]
        },
        "requiresManualRightsReview": { "type": "boolean" }
      }
    }
  }
}
