{
  "name": "mediengestalter-pruefung-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "build/electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "tsx watch server/index.ts",
    "dev:web": "vite --host 127.0.0.1",
    "typecheck": "tsc --noEmit",
    "build:web": "vite build",
    "build:node": "esbuild server/index.ts scripts/gradeAttempt.ts scripts/validateExamPackage.ts scripts/packageSmoke.ts electron/main.ts --bundle --platform=node --format=esm --outbase=. --outdir=build --packages=external --external:electron",
    "build": "npm run typecheck && npm run build:web && npm run build:node",
    "serve": "node build/server/index.js",
    "package": "npm run build && electron-builder --dir",
    "package:dist": "npm run build && electron-builder",
    "package:smoke": "npm run build && node build/scripts/packageSmoke.js",
    "test": "vitest run",
    "validate:exam": "tsx scripts/validateExamPackage.ts",
    "grade": "tsx scripts/gradeAttempt.ts"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "express": "^5.2.1",
    "lucide-react": "^0.468.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "vitest": "^4.0.15"
  },
  "build": {
    "appId": "de.local.mediengestalter.pruefungstrainer",
    "productName": "Pruefungstrainer Printmedien",
    "directories": {
      "output": "release"
    },
    "files": [
      "build/server/**/*",
      "build/electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist",
        "to": "dist"
      },
      {
        "from": "data/exams",
        "to": "data/exams",
        "filter": [
          "**/*",
          "!**/solution.json"
        ]
      },
      {
        "from": "data/schemas",
        "to": "data/schemas"
      },
      {
        "from": "data/templates",
        "to": "data/templates"
      }
    ]
  }
}
